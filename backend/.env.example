# ===========================================================
# AI PDF Chatbot – Backend Environment Variables
# ===========================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ---- Application --------------------------------------------------- #
APP_NAME="AI PDF Chatbot"
APP_VERSION="1.0.0"
DEBUG=False

# ---- Server --------------------------------------------------------- #
HOST=0.0.0.0
PORT=8000

# ---- Logging -------------------------------------------------------- #
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---- CORS ----------------------------------------------------------- #
# Comma-separated list of origins that may call the API.
# Defaults are set in config.py for local Unity development.
# ALLOWED_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# ---- OpenRouter (Phase 2+) ----------------------------------------- #
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# ---- PDF Knowledge Base (Phase 3+) --------------------------------- #
KNOWLEDGE_BASE_PATH=knowledge_base/AI_Knowledge_Base.pdf
